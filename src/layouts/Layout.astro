---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle";

interface Props {
	title?: string;
}
const { title = "Timetable Generator" } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1.0, viewport-fit=cover"
		/>
		<meta
			name="description"
			content="Auto-generate school timetables with smart scheduling. No conflicts, fair distribution."
		/>
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<script is:inline>
			const getTheme = () => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					return "dark";
				}
				return "light";
			};
			document.documentElement.setAttribute("data-theme", getTheme());
		</script>
	</head>
	<body>
		<header class="app-header">
			<div class="header-inner">
				<a href="/" class="logo">
					<span class="logo-icon">📅</span>
					TimeTable Pro
				</a>

				<!-- Desktop nav -->
				<nav class="nav-desktop">
					<ul class="nav-links">
						<li>
							<a
								href="/"
								class:list={[{ active: pathname === "/" }]}
								>View Timetable</a
							>
						</li>
						<li>
							<a
								href="/admin"
								class:list={[{ active: pathname === "/admin" }]}
								>Admin</a
							>
						</li>
					</ul>
				</nav>

				<div class="header-actions">
					<ThemeToggle client:load />
				</div>
			</div>
		</header>

		<main class="main-content">
			<slot />
		</main>

		<!-- iOS-style bottom tab bar for mobile -->
		<nav class="mobile-tab-bar" aria-label="Mobile navigation">
			<a
				href="/"
				class:list={["mobile-tab", { active: pathname === "/" }]}
			>
				<span class="mobile-tab-icon">📅</span>
				<span class="mobile-tab-label">Timetable</span>
			</a>
			<a
				href="/admin"
				class:list={["mobile-tab", { active: pathname === "/admin" }]}
			>
				<span class="mobile-tab-icon">⚙️</span>
				<span class="mobile-tab-label">Admin</span>
			</a>
		</nav>
	</body>
</html>
